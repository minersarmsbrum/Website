# Auth credentials — change these before deploying to production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password-here
STAFF_USERNAME=staff
STAFF_PASSWORD=your-staff-password-here

# Session encryption key — must be at least 32 characters, keep secret
# Generate one with: node -e "require('crypto').randomBytes(32).toString('hex')|console.log"
SESSION_PASSWORD=generate-a-random-32-char-string-here

# Supabase — required for gallery file uploads
# 1. Create a free project at https://supabase.com
# 2. Go to Storage → Create bucket named "gallery" (set to Public)
# 3. Go to Settings → API and copy the values below
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
