# ============================================================
# THE MINERS ARMS — Environment Variables Template
# Copy this file to .env.local and fill in the values.
# ⚠️  NEVER put real secrets in this file — it is committed.
# ============================================================


# ─────────────────────────────────────────
# PORTAL AUTH CREDENTIALS
# ─────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password-here
STAFF_USERNAME=staff
STAFF_PASSWORD=your-staff-password-here


# ─────────────────────────────────────────
# SESSION ENCRYPTION
# ─────────────────────────────────────────
# Must be at least 32 characters — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_PASSWORD=generate-a-random-32-char-string-here


# ─────────────────────────────────────────
# SITE URL
# ─────────────────────────────────────────
# Local dev: http://localhost:3000 | Production: https://theminersarms.co.uk
NEXT_PUBLIC_SITE_URL=https://theminersarms.co.uk


# ─────────────────────────────────────────
# SUPABASE
# ─────────────────────────────────────────
# Required for gallery photo uploads and storage
# Setup: https://supabase.com → New Project → Storage → Create bucket "gallery" (Public)
# Keys: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# ─────────────────────────────────────────
# EMAIL — TRANSACTIONAL (Resend)
# ─────────────────────────────────────────
# For booking confirmations, contact form emails, and admin alerts
# Setup: https://resend.com → API Keys → Create Key
RESEND_API_KEY=re_your-resend-api-key-here
EMAIL_FROM=bookings@theminersarms.co.uk
EMAIL_TO_ADMIN=manager@theminersarms.co.uk


# ─────────────────────────────────────────
# GOOGLE — MAPS & ANALYTICS
# ─────────────────────────────────────────
# Maps API Key: console.cloud.google.com → APIs & Services → Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Place ID: https://developers.google.com/maps/documentation/javascript/examples/places-placeid-finder
NEXT_PUBLIC_GOOGLE_PLACE_ID=ChIJ_your-place-id-here

# GA4 Measurement ID: analytics.google.com → Admin → Data Streams → Web
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX


# ─────────────────────────────────────────
# STRIPE — PAYMENT PROCESSING (optional)
# ─────────────────────────────────────────
# For booking deposits or event ticket payments
# Setup: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret-here


# ─────────────────────────────────────────
# TELEGRAM — NOTIFICATION BOT
# ─────────────────────────────────────────
# Single bot for all notifications: new bookings and daily 8am summary
# Create via @BotFather on Telegram → /newbot → copy the token
# Get the Chat ID: add the bot to your group, send any message, then visit:
# https://api.telegram.org/bot<TOKEN>/getUpdates → look for "chat":{"id":...}
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here


# ─────────────────────────────────────────
# CRON JOB SECRET
# ─────────────────────────────────────────
# Secures the /api/cron/* endpoints from unauthorised calls.
# Vercel passes this automatically; set the same value in your Vercel project env vars.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=generate-a-random-secret-here


# ─────────────────────────────────────────
# SOCIAL & REVIEW FEEDS (optional)
# ─────────────────────────────────────────
# Instagram feed embed: developers.facebook.com → Instagram Basic Display API
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token-here

# Facebook reviews/posts embed: developers.facebook.com → Graph API Explorer
FACEBOOK_PAGE_ACCESS_TOKEN=your-facebook-page-access-token-here

# Google Reviews (separate restricted key from Cloud Console)
GOOGLE_REVIEWS_API_KEY=your-google-reviews-api-key-here
